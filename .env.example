# 默认：拆解 list 用 Gemini/Banana，图像生成也用 Gemini/Banana
DEFAULT_LIST_ANALYZER=gemini
DEFAULT_IMAGE_GENERATOR=gemini

# Gemini / Nano Banana
GEMINI_API_KEY=填你的_gemini_key
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# OpenAI
OPENAI_API_KEY=填你的_openai_key
OPENAI_VISION_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1

# Claude，仅用于拆解 list
ANTHROPIC_API_KEY=填你的_anthropic_key
ANTHROPIC_MODEL=claude-opus-4-7
